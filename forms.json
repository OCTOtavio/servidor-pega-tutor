{
  "Title": "Registros - Desvio de conduta/Situação Atípica",

  "Sections": [
    {
      "Title": "Informações Iniciais",

      "Content": [

        {
          "Type": "Email",
          "Title": "No campo abaixo, PREENCHER COM SEU EMAIL",
          "Required": true
        },

        {
          "Type": "Checkbox",

          "Title": "Selecione o tutor",

          "Description": "DETALHE: CASO MARQUE A OPÇÃO \"Outro\", DIGITE EXATAMENTE ASSIM: \"Nome - e-mail\"",

          "Required": true,
          "Multiple_Choice": true,
          "Other_Choice": true,

          "Dynamic_Source": {
            "URL": "https://octotavio.github.io/servidor-pega-tutor/tutores.json",

            "Mode": "tutor_emails",

            "Format": "{tutor} - {email}"
          }
        }
      ]
    },

    {
      "Title": "Tutor e Tutorados",

      "Dynamic_Sections": {

        "URL": "https://octotavio.github.io/servidor-pega-tutor/tutores.json",

        "Mode": "tutor_students",

        "Template": {

          "Type": "Checkbox",

          "Title": "{tutor}",

          "Multiple_Choice": true,

          "Choices_From": "alunos"
        }
      }
    },

    {
      "Title": "Ocorrência",

      "Content": [

        {
          "Type": "Dropdown",

          "Title": "Turma",

          "Required": true,

          "Choices": [
            "6ºA",
            "6ºB",
            "7ºA",
            "7ºB",
            "8ºA",
            "8ºB",
            "9ºA",
            "9ºB",
            "1ºA",
            "2ºA"
          ]
        },

        {
          "Type": "Text",
          "Title": "Disciplina",
          "Required": true
        },

        {
          "Type": "Date",
          "Title": "Data",
          "Required": true
        },

        {
          "Type": "Checkbox",

          "Title": "Motivo",

          "Required": true,

          "Multiple_Choice": true,

          "Other_Choice": true,

          "Choices": [
            "Questões disciplinares - Saída injustificada",
            "Questões disciplinares - Utilização indevida de aparelhos eletrônicos",
            "Questões de convivência - Agressão física",
            "Questões de convivência - Bullying",
            "Outro"
          ]
        },

        {
          "Type": "Paragraph",
          "Title": "Descreva o acontecimento",
          "Required": true
        },

        {
          "Type": "MultipleChoice",
          "Title": "É necessário atendimento com Vice Diretor - CONVIVA",

          "Choices": [
            "Sim",
            "Não"
          ]
        },

        {
          "Type": "MultipleChoice",
          "Title": "É necessária uma conversa do tutor com o aluno",

          "Required": true,

          "Choices": [
            "Sim",
            "Não"
          ]
        },

        {
          "Type": "MultipleChoice",
          "Title": "É necessária uma reunião com responsável, tutor, vice e professor?",

          "Required": true,

          "Choices": [
            "Sim",
            "Não"
          ]
        }

      ]
    }
  ]
}
