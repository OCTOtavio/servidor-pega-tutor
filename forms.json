{
  "Title": "Registros - Desvio de conduta/Situação Atípica",

  "Sections": [
    {
      "Title": "Informações Iniciais",

      "Questions": [
        {
          "Type": "Email",
          "Title": "No campo abaixo, PREENCHER COM SEU NOME",
          "Required": true
        },

        {
          "Type": "Checkbox",
          "Title": "Selecione o tutor",

          "Description": "DETALHE: CASO MARQUE A OPÇÃO \"Outro\", DIGITE EXATAMENTE ASSIM: \"Nome - e-mail\", CASO SEJA VÁRIOS E-MAILS, SEPARAR POR VÍRGULA (\", \")",

          "Required": true,

          "Other_Choice": true,

          "Dynamic_Source": {
            "URL": "https://octotavio.github.io/servidor-pega-tutor/tutores.json",

            "Mode": "Tutor_Email_List"
          }
        }
      ]
    },

    {
      "Title": "TUTOR E TUTORADOS",

      "Dynamic_Sections": {
        "URL": "https://octotavio.github.io/servidor-pega-tutor/tutores.json",

        "Mode": "Tutor_Alunos_Checkboxes",

        "Question_Type": "Checkbox",

        "Required": false
      }
    },

    {
      "Title": "Dados da Ocorrência",

      "Questions": [
        {
          "Type": "MultipleChoice",
          "Title": "Turma",
          "Required": true,

          "Choices": [
            "6ºA",
            "6ºB",
            "7ºA",
            "7ºB",
            "8ºA",
            "8ºB",
            "9ºA",
            "9ºB",
            "1ºA",
            "2ºA"
          ]
        },

        {
          "Type": "Text",
          "Title": "Disciplina",
          "Required": true
        },

        {
          "Type": "Date",
          "Title": "Data",
          "Required": true
        },

        {
          "Type": "Checkbox",
          "Title": "Motivo",
          "Required": true,

          "Choices": [
            "Questões disciplinares - Saída injustificada de atividade pedagógica/sala de aula",
            "Questões disciplinares - Utilização indevida de aparallhos eletrônicos",
            "Questões disciplinares - Desrespeito ao professor com palavrões e/ou gestos",
            "Questões disciplinares - Atraso para entrar na aula",
            "Questões pedagógicas - Atrapalha o desenvolvimento da aula",
            "Questões pedagógicas - Não realizou as atividades",
            "Questões de convivência - Agressão física",
            "Questões de convivência - Agressão verbal",
            "Questões de convivência - Ameaças",
            "Questões de convivência - Bullying/ Humilhação sistemática",
            "Questões de convivência - Discriminação",
            "Danos e outros crimes contra o patrimônio - Furto/ Vandalismo/ Depredação",
            "Posse ou encontro de armas ou objetos perigosos",
            "Consumo/venda de álcool, outras drogas e/ou consumo de drogas ilícitas",
            "Outro"
          ]
        },

        {
          "Type": "Paragraph",
          "Title": "Descreva o acontecimento",
          "Required": true
        },

        {
          "Type": "MultipleChoice",
          "Title": "É necessário atendimento com Vice Diretor - CONVIVA",

          "Choices": [
            "Sim",
            "Não"
          ]
        },

        {
          "Type": "MultipleChoice",
          "Title": "É necessária uma conversa do tutor com o aluno",

          "Required": true,

          "Choices": [
            "Sim",
            "Não"
          ]
        },

        {
          "Type": "MultipleChoice",
          "Title": "É necessária uma reunião com responsável, tutor, vice e professor?",

          "Required": true,

          "Choices": [
            "Sim",
            "Não"
          ]
        }
      ]
    }
  ]
}
